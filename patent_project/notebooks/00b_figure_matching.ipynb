 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 00b - VLM Figure Matching
",
    "
",
    "This notebook uses the `VLMMatcher` to process patent drawings, identify sub-figures using a Vision-Language Model, crop them, and save them for further analysis."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 1: Environment Setup
",
    "# Load environment, system paths, config.yaml, and dataframes.
",
    "
",
    "import yaml
",
    "from pathlib import Path
",
    "import pandas as pd
",
    "import sys
",
    "from IPython.display import display
",
    "
",
    "# Add the 'src' directory to the Python path to import our custom module
",
    "project_dir = Path.cwd().parent
",
    "sys.path.append(str(project_dir))
",
    "
",
    "from src.figure_matcher import VLMMatcher
",
    "
",
    "# Load configuration
",
    "config_path = project_dir / 'config.yaml'
",
    "with open(config_path, 'r') as f:
",
    "    config = yaml.safe_load(f)
",
    "
",
    "print(f"Configuration loaded from {config_path}")
",
    "
",
    "# Create a dummy dataframe for demonstration purposes
",
    "# In a real scenario, this would be loaded from a CSV or database
",
    "data = {
",
    "    'patent_id': [f'patent_{i:03d}' for i in range(1, 11)],
",
    "    'assignee': [f'Company {chr(65+i)}' for i in range(10)]
",
    "}
",
    "df = pd.DataFrame(data)
",
    "
",
    "# Also create dummy image files for the notebook to run
",
    "raw_images_path = Path(config['paths']['raw_images'])
",
    "for patent_id in df['patent_id']:
",
    "    patent_image_dir = raw_images_path / patent_id
",
    "    patent_image_dir.mkdir(parents=True, exist_ok=True)
",
    "    dummy_image_path = patent_image_dir / 'drawing.png'
",
    "    if not dummy_image_path.exists():
",
    "        # Create a simple placeholder image
",
    "        import numpy as np
",
    "        import cv2
",
    "        placeholder_img = np.ones((512, 512, 3), dtype=np.uint8) * 255
",
    "        cv2.putText(placeholder_img, f'{patent_id}', (50, 256), cv2.FONT_HERSHEY_SIMPLEX, 1, (0, 0, 0), 2)
",
    "        cv2.imwrite(str(dummy_image_path), placeholder_img)
",
    "
",
    "print("Dummy data and image files created for demonstration.")
",
    "print("
Patents to be processed:")
",
    "display(df)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 2: Instantiate VLM Matcher
",
    "# This loads the Qwen2.5-VL-7B-Instruct model into GPU VRAM.
",
    "# This step is resource-intensive and may take some time.
",
    "
",
    "vlm_matcher = VLMMatcher(model_id=config['model_id'])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 3: Process All Patents
",
    "# Process all patents sequentially using a `scan_limit` from the config for development testing.
",
    "
",
    "from tqdm.auto import tqdm
",
    "
",
    "scan_limit = config.get('scan_limit', len(df))
",
    "raw_images_dir = Path(config['paths']['raw_images'])
",
    "output_dir = Path(config['paths']['matched'])
",
    "
",
    "results = []
",
    "
",
    "for _, row in tqdm(df.head(scan_limit).iterrows(), total=scan_limit, desc="Processing Patents"):
",
    "    patent_id = row['patent_id']
",
    "    image_folder = raw_images_dir / patent_id
",
    "    # Assuming the main drawing is named 'drawing.png'
",
    "    image_path = image_folder / 'drawing.png'
",
    "
",
    "    if not image_path.exists():
",
    "        status = 'error'
",
    "        reason = f'Image not found: {image_path}'
",
    "        results.append({'patent_id': patent_id, 'status': status, 'reason': reason})
",
    "        print(f"Skipping {patent_id}: {reason}")
",
    "        continue
",
    "    
",
    "    try:
",
    "        vlm_matcher.process_image(
",
    "            image_path=image_path,
",
    "            patent_id=patent_id,
",
    "            output_dir=(output_dir / patent_id)
",
    "        )
",
    "        status = 'success'
",
    "        reason = ''
",
    "    except Exception as e:
",
    "        status = 'error'
",
    "        reason = str(e)
",
    "        print(f"An error occurred while processing {patent_id}: {e}")
",
    "    
",
    "    results.append({'patent_id': patent_id, 'status': status, 'reason': reason})
",
    "
",
    "print("
Processing complete.")
",
    "results_df = pd.DataFrame(results)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 4: Review Results
",
    "# Group results to show a summary count of success vs review cases, and display a sample dataframe.
",
    "
",
    "print("--- Processing Summary ---")
",
    "summary = results_df['status'].value_counts().reset_index()
",
    "summary.columns = ['Status', 'Count']
",
    "display(summary)
",
    "
",
    "success_df = results_df[results_df['status'] == 'success']
",
    "review_df = results_df[results_df['status'] == 'error']
",
    "
",
    "print("
--- Sample of Successfully Processed Patents ---")
",
    "display(success_df.head())
",
    "
",
    "if not review_df.empty:
",
    "    print("
--- Patents Requiring Review ---")
",
    "    display(review_df)
",
    "else:
",
    "    print("
Excellent! No patents require manual review.")
"
   ]
  }
 ],
